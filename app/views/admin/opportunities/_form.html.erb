<%# app/views/admin/opportunities/_form.html.erb - VERSION AVEC SYSTÈME IMAGE_1/2/3 %>

<%= form_with model: [:admin, @opportunity],
              local: true,
              html: { multipart: true, class: "admin-form-improved" } do |f| %>

  <% if @opportunity.errors.any? %>
    <div class="form-errors" style="background: #fee2e2; border: 1px solid #f87171; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
      <h2 style="color: #991b1b; margin: 0 0 0.5rem 0;"><%= pluralize(@opportunity.errors.count, "erreur") %> :</h2>
      <ul style="margin: 0; padding-left: 1.5rem;">
        <% @opportunity.errors.full_messages.each do |m| %>
          <li style="color: #991b1b;"><%= m %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ========== IMPORT OPPORTUNITÉ (BÊTA) ========== %>
  <div class="form-section" style="border: 2px dashed #fb923c; background: #fff7ed;">
    <h3 class="form-section-title">⚡ Import Opportunité (bêta)</h3>
    <p class="form-section-subtitle">
      Collez un bloc complet (frontmatter + description). À l'enregistrement, les champs seront pré-remplis.
    </p>

    <div class="field">
      <label class="field-label">Bloc Import</label>
      <%= text_area_tag :import_blob, params[:import_blob],
            rows: 12,
            placeholder: <<~TXT,
---
title: "🧶 Aidez à acheminer des tricots solidaires"
category: benevolat
organization: Collectif solidaire de Fraize
location: "Fraize, Vosges"
lat: 48.1736
lng: 6.9987
time_commitment: "Selon disponibilité"
quote: "À 99 ans, je tricote pour les enfants."
quote_author: "Marie-Louise"
source_url: "https://www.vosgesmatin.fr/..."
website: "https://..."
contact_email: "contact@..."
contact_phone: "06 12 34 56 78"
tags:
  - solidarité
  - bénévolat
  - Ukraine
---
Ici la **description complète** de l'opportunité, réécrite, claire et actionnable.
TXT
            class: "field-input",
            style: "font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;" %>

      <div class="field-hint">💡 Si ce bloc est renseigné, il est prioritaire sur les champs ci-dessous.</div>
    </div>
  </div>

  <div class="form-sections">

    <%# ========== SECTION 1 : INFORMATIONS PRINCIPALES ========== %>
    <div class="form-section">
      <h3 class="form-section-title">📝 Contenu Principal</h3>
      <p class="form-section-subtitle">Informations essentielles de l'opportunité</p>

      <div class="form-row">
        <div class="field" style="flex: 2;">
          <%= f.label :title, "Titre *", class: "field-label" %>
          <%= f.text_field :title, placeholder: "Ex: Rejoignez le Repair Café de Nancy", class: "field-input" %>
        </div>

        <div class="field">
          <%= f.label :category, "Catégorie *", class: "field-label" %>
          <%= f.select :category,
                [
                  ["Bénévolat", "benevolat"],
                  ["Formation", "formation"],
                  ["Rencontres", "rencontres"],
                  ["Entreprendre", "entreprendre"],
                  ["Écologiser", "ecologiser"]
                ],
                { include_blank: "(choisir)" },
                { class: "field-input" } %>
        </div>

        <div class="field">
          <%= f.label :organization, "Organisation *", class: "field-label" %>
          <%= f.text_field :organization, placeholder: "Ex: Repair Café Nancy", class: "field-input" %>
        </div>
      </div>

      <div class="field">
        <%= f.label :description, "Description (Markdown supporté) *", class: "field-label" %>
        <%= f.text_area :description, rows: 12, placeholder: "Description complète de l'opportunité...", class: "field-input" %>
        <div class="field-hint">
          ✨ Vous pouvez utiliser :<br>
          • **texte** pour mettre en gras<br>
          • Emojis : ✨ 💡 🔥<br>
          • Photos inline : insérez <code>&lt;!-- IMAGE_1 --&gt;</code>, <code>&lt;!-- IMAGE_2 --&gt;</code>, <code>&lt;!-- IMAGE_3 --&gt;</code> (voir section Images ci-dessous ⬇️)
        </div>
      </div>

      <div class="field">
        <label class="checkbox-field">
          <%= f.check_box :is_active %>
          <span>✅ Visible sur le site (publier l'opportunité)</span>
        </label>
      </div>
    </div>

    <%# ========== SECTION 2 : CITATION / TÉMOIGNAGE ========== %>
    <div class="form-section">
      <h3 class="form-section-title">💬 Citation / Témoignage</h3>
      <p class="form-section-subtitle">Citation inspirante d'un participant (optionnel)</p>

      <div class="field">
        <%= f.label :quote, "Citation inspirante", class: "field-label" %>
        <%= f.text_area :quote, rows: 3, placeholder: "« En 48h, j'avais 15 messages de personnes prêtes à aider... »", class: "field-input" %>
        <div class="field-hint">Ajoutez les guillemets « » si vous le souhaitez</div>
      </div>

      <div class="field">
        <%= f.label :quote_author, "Auteur de la citation", class: "field-label" %>
        <%= f.text_field :quote_author, placeholder: "Marie, fondatrice du Repair Café", class: "field-input" %>
      </div>
    </div>

    <%# ========== SECTION 3 : STATISTIQUES D'IMPACT ========== %>
    <div class="form-section">
      <h3 class="form-section-title">📊 Statistiques d'impact</h3>
      <p class="form-section-subtitle">Jusqu'à 4 statistiques clés (optionnel)</p>

      <div class="stats-grid">
        <div class="stat-pair">
          <div class="field">
            <%= f.label :stat_1_number, "Stat 1 - Nombre", class: "field-label" %>
            <%= f.text_field :stat_1_number, placeholder: "200+", class: "field-input" %>
          </div>
          <div class="field">
            <%= f.label :stat_1_label, "Stat 1 - Label", class: "field-label" %>
            <%= f.text_field :stat_1_label, placeholder: "objets réparés", class: "field-input" %>
          </div>
        </div>

        <div class="stat-pair">
          <div class="field">
            <%= f.label :stat_2_number, "Stat 2 - Nombre", class: "field-label" %>
            <%= f.text_field :stat_2_number, placeholder: "45", class: "field-input" %>
          </div>
          <div class="field">
            <%= f.label :stat_2_label, "Stat 2 - Label", class: "field-label" %>
            <%= f.text_field :stat_2_label, placeholder: "participants réguliers", class: "field-input" %>
          </div>
        </div>

        <div class="stat-pair">
          <div class="field">
            <%= f.label :stat_3_number, "Stat 3 - Nombre", class: "field-label" %>
            <%= f.text_field :stat_3_number, placeholder: "3 ans", class: "field-input" %>
          </div>
          <div class="field">
            <%= f.label :stat_3_label, "Stat 3 - Label", class: "field-label" %>
            <%= f.text_field :stat_3_label, placeholder: "d'existence", class: "field-input" %>
          </div>
        </div>

        <div class="stat-pair">
          <div class="field">
            <%= f.label :stat_4_number, "Stat 4 - Nombre", class: "field-label" %>
            <%= f.text_field :stat_4_number, placeholder: "2x", class: "field-input" %>
          </div>
          <div class="field">
            <%= f.label :stat_4_label, "Stat 4 - Label", class: "field-label" %>
            <%= f.text_field :stat_4_label, placeholder: "par mois", class: "field-input" %>
          </div>
        </div>
      </div>
    </div>

    <%# ========== SECTION 4 : DÉFIS SURMONTÉS ========== %>
    <div class="form-section">
      <h3 class="form-section-title">🔥 Défis surmontés</h3>
      <p class="form-section-subtitle">Un défi par ligne (format: **Défi:** Solution)</p>

      <div class="field">
        <%= f.label :challenges, "Défis surmontés", class: "field-label" %>
        <%= f.text_area :challenges, rows: 6, class: "field-input", placeholder: "**Trouver un lieu :** Négociation avec la mairie pendant 2 mois
**Financement :** Campagne de dons qui a réuni 5000€
**Mobiliser les bénévoles :** Réunions publiques mensuelles" %>
        <div class="field-hint">Un défi par ligne. Utilisez **Défi:** Solution</div>
      </div>
    </div>

    <%# ========== SECTION 5 : LOCALISATION ========== %>
    <div class="form-section">
      <h3 class="form-section-title">📍 Localisation</h3>
      <p class="form-section-subtitle">Adresse et coordonnées GPS</p>

      <div class="field">
        <%= f.label :address, "Adresse (affichage court)", class: "field-label" %>
        <%= f.text_field :address, placeholder: "6 Rue du Coq, Lunéville", class: "field-input" %>
        <div class="field-hint">📍 Adresse courte affichée dans l'index admin et sur la fiche publique</div>
      </div>

      <div class="field">
        <%= f.label :location, "Adresse complète (pour Google Maps)", class: "field-label" %>
        <%= f.text_field :location, placeholder: "6 Rue du Coq, 54300 Lunéville, France", class: "field-input" %>
        <div class="field-hint">🗺️ Utilisée pour la géolocalisation et le lien Google Maps</div>
      </div>

      <div class="form-row">
        <div class="field">
          <%= f.label :latitude, "Latitude", class: "field-label" %>
          <%= f.text_field :latitude, placeholder: "48.6937", step: "any", class: "field-input" %>
        </div>
        <div class="field">
          <%= f.label :longitude, "Longitude", class: "field-label" %>
          <%= f.text_field :longitude, placeholder: "6.1844", step: "any", class: "field-input" %>
        </div>
      </div>

      <div class="field-hint">
        💡 <a href="https://www.latlong.net/" target="_blank" rel="noopener">Trouver lat/lng sur LatLong.net</a>
      </div>
    </div>

    <%# ========== SECTION 6 : DATES & HORAIRES ========== %>
    <div class="form-section">
      <h3 class="form-section-title">📅 Dates & horaires</h3>
      <p class="form-section-subtitle">Période et temps d'engagement</p>

      <div class="form-row">
        <div class="field">
          <%= f.label :start_date, "Début", class: "field-label" %>
          <%= f.date_field :start_date, class: "field-input" %>
        </div>
        <div class="field">
          <%= f.label :end_date, "Fin", class: "field-label" %>
          <%= f.date_field :end_date, class: "field-input" %>
        </div>
      </div>

      <div class="field">
        <%= f.label :time_commitment, "Engagement en temps", class: "field-label" %>
        <%= f.text_field :time_commitment, placeholder: "2h par semaine", class: "field-input" %>
      </div>
    </div>

    <%# ========== SECTION 7 : IMAGES (SYSTÈME INLINE) ========== %>
    <div class="form-section" style="border: 2px solid #3b82f6; background: #eff6ff;">
      <h3 class="form-section-title">🖼️ Images (Système Inline)</h3>
      <p class="form-section-subtitle">Uploadez jusqu'à 3 photos et placez-les dans le texte avec &lt;!-- IMAGE_X --&gt;</p>

      <div style="background: #dbeafe; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; border-left: 4px solid #3b82f6;">
        <p style="margin: 0 0 0.75rem 0; font-weight: 700; color: #1e40af;">💡 Comment utiliser les images inline :</p>
        <ol style="margin: 0; padding-left: 1.5rem; color: #1e3a8a; font-size: 0.9rem;">
          <li style="margin-bottom: 0.5rem;">Uploadez vos photos ci-dessous (Photo 1, 2 et 3)</li>
          <li style="margin-bottom: 0.5rem;">Dans le champ <strong>Description</strong> ci-dessus, placez ces balises où vous voulez que les photos apparaissent :
            <ul style="margin-top: 0.25rem; list-style-type: circle; padding-left: 1.5rem;">
              <li style="margin-bottom: 0.25rem;"><code style="background: white; padding: 2px 6px; border-radius: 3px;">&lt;!-- IMAGE_1 --&gt;</code> pour la photo 1 (flotte à gauche)</li>
              <li style="margin-bottom: 0.25rem;"><code style="background: white; padding: 2px 6px; border-radius: 3px;">&lt;!-- IMAGE_2 --&gt;</code> pour la photo 2 (flotte à droite)</li>
              <li style="margin-bottom: 0.25rem;"><code style="background: white; padding: 2px 6px; border-radius: 3px;">&lt;!-- IMAGE_3 --&gt;</code> pour la photo 3 (pleine largeur)</li>
            </ul>
            <li>Les photos s'afficheront automatiquement à ces endroits dans le texte !</li>
          </ol>

          <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #93c5fd;">
            <p style="margin: 0 0 0.5rem 0; color: #1e40af; font-weight: 600; font-size: 0.9rem;">
              📝 Exemple d'utilisation dans la Description :
            </p>
            <div style="background: white; padding: 0.75rem; border-radius: 0.375rem; font-family: monospace; font-size: 0.8rem; color: #334155; white-space: pre-wrap; overflow-x: auto;">Le Repair Café de Nancy accueille chaque semaine des bénévoles...

&lt;!-- IMAGE_1 --&gt;

Depuis 3 ans, nous avons réparé plus de 200 objets...

&lt;!-- IMAGE_2 --&gt;

L'atelier est ouvert tous les samedis après-midi...

&lt;!-- IMAGE_3 --&gt;</div>
          </div>
        </div>
      </div>

      <%# Photo 1 : Flotte à gauche %>
      <div class="field">
        <%= f.label :inline_image_1, "📷 Photo 1 (gauche)", class: "field-label" %>
        <%= f.file_field :inline_image_1, accept: "image/png,image/jpeg,image/jpg,image/gif,image/webp", class: "field-input" %>
        <div class="field-hint">
          Insérez <code>&lt;!-- IMAGE_1 --&gt;</code> dans la Description pour placer cette photo
        </div>
      </div>

      <div class="field">
        <%= f.label :inline_caption_1, "Légende Photo 1", class: "field-label" %>
        <%= f.text_field :inline_caption_1, placeholder: "Des bénévoles réparent une cafetière", class: "field-input" %>
      </div>

      <%# Photo 2 : Flotte à droite %>
      <div class="field">
        <%= f.label :inline_image_2, "📷 Photo 2 (droite)", class: "field-label" %>
        <%= f.file_field :inline_image_2, accept: "image/png,image/jpeg,image/jpg,image/gif,image/webp", class: "field-input" %>
        <div class="field-hint">
          Insérez <code>&lt;!-- IMAGE_2 --&gt;</code> dans la Description pour placer cette photo
        </div>
      </div>

      <div class="field">
        <%= f.label :inline_caption_2, "Légende Photo 2", class: "field-label" %>
        <%= f.text_field :inline_caption_2, placeholder: "L'atelier du Repair Café", class: "field-input" %>
      </div>

      <%# Photo 3 : Pleine largeur %>
      <div class="field">
        <%= f.label :inline_image_3, "📷 Photo 3 (pleine largeur)", class: "field-label" %>
        <%= f.file_field :inline_image_3, accept: "image/png,image/jpeg,image/jpg,image/gif,image/webp", class: "field-input" %>
        <div class="field-hint">
          Insérez <code>&lt;!-- IMAGE_3 --&gt;</code> dans la Description pour placer cette photo
        </div>
      </div>

      <div class="field">
        <%= f.label :inline_caption_3, "Légende Photo 3", class: "field-label" %>
        <%= f.text_field :inline_caption_3, placeholder: "Vue d'ensemble de l'atelier", class: "field-input" %>
      </div>
    </div>

    <%# ========== SECTION 8 : SOURCE & CONTACT ========== %>
    <div class="form-section">
      <h3 class="form-section-title">📰 Source & Contact</h3>
      <p class="form-section-subtitle">Informations de référence et liens d'action</p>

      <div class="form-row">
        <div class="field">
          <%= f.label :source_name, "Nom de la source", class: "field-label" %>
          <%= f.text_field :source_name, placeholder: "L'Est Républicain", class: "field-input" %>
        </div>
        <div class="field" style="flex: 2;">
          <%= f.label :source_url, "URL source (article)", class: "field-label" %>
          <%= f.text_field :source_url, placeholder: "https://www.estrepublicain.fr/...", class: "field-input" %>
          <div class="field-hint">🔗 Crée le bouton "📄 En savoir plus" dans la section CTA</div>
        </div>
      </div>

      <div class="field">
        <%= f.label :website, "Site web de l'organisation", class: "field-label" %>
        <%= f.text_field :website, placeholder: "https://sandcreation.fr", class: "field-input" %>
        <div class="field-hint">
          🎯 <strong>Important :</strong> Crée le bouton principal dans la section "Prêt à passer à l'action"
        </div>
      </div>

      <div class="field">
        <%= f.label :contact_email, "Email de contact", class: "field-label" %>
        <%= f.email_field :contact_email, placeholder: "contact@sandcreation.fr", class: "field-input" %>
        <div class="field-hint">💬 Crée le bouton "Contacter l'organisation"</div>
      </div>

      <div class="field">
        <%= f.label :contact_phone, "Téléphone de contact", class: "field-label" %>
        <%= f.telephone_field :contact_phone, placeholder: "06 12 34 56 78", class: "field-input" %>
        <div class="field-hint">📱 Optionnel - Affiché dans l'encadré d'infos</div>
      </div>
    </div>

    <%# ========== SECTION 9 : SEO & TAGS ========== %>
    <div class="form-section">
      <h3 class="form-section-title">🏷️ SEO & Organisation</h3>
      <p class="form-section-subtitle">Identifiant unique et mots-clés</p>

      <div class="form-row">
        <div class="field" style="flex: 2;">
          <%= f.label :slug, "Slug (URL)", class: "field-label" %>
          <%= f.text_field :slug, placeholder: "repair-cafe-nancy", class: "field-input" %>
          <div class="field-hint">Laissez vide pour génération automatique</div>
        </div>
        <div class="field">
          <%= f.label :tags, "Tags", class: "field-label" %>
          <%= f.text_field :tags, placeholder: "réparation, écologie, bénévolat", class: "field-input" %>
          <div class="field-hint">Séparés par des virgules</div>
        </div>
      </div>
    </div>

  </div>

  <%# ACTIONS %>
  <div class="form-actions">
    <%= f.submit "Enregistrer", class: "btn-primary" %>
    <%= link_to "Annuler", admin_opportunities_path, class: "btn-secondary" %>
  </div>

<% end %>

<style>
/* Styles pour le formulaire amélioré */
.admin-form-improved { max-width: 1200px; margin: 0 auto; }

.form-sections { display: flex; flex-direction: column; gap: 2rem; }

.form-section {
  background: white;
  border: 2px solid #e2e8f0;
  border-radius: 1rem;
  padding: 1.5rem;
}

.form-section-title {
  font-size: 1.25rem;
  font-weight: 800;
  color: #0f172a;
  margin: 0 0 0.25rem 0;
}

.form-section-subtitle {
  font-size: 0.875rem;
  color: #64748b;
  margin: 0 0 1.5rem 0;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
  margin-bottom: 1rem;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.field-label {
  font-weight: 700;
  color: #334155;
  font-size: 0.875rem;
}

.field-input {
  padding: 0.75rem;
  border: 1px solid #cbd5e1;
  border-radius: 0.5rem;
  font-size: 1rem;
  width: 100%;
}

.field-input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.field-hint {
  font-size: 0.75rem;
  color: #64748b;
  margin-top: 0.25rem;
}

.field-hint a {
  color: #3b82f6;
  text-decoration: underline;
}

.checkbox-field {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  color: #334155;
  cursor: pointer;
}

.checkbox-field input[type="checkbox"] {
  width: 20px;
  height: 20px;
  cursor: pointer;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1rem;
}

.stat-pair {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 0.5rem;
}

.form-actions {
  display: flex;
  gap: 1rem;
  padding: 1.5rem 0;
  border-top: 2px solid #e2e8f0;
  margin-top: 2rem;
}

.btn-primary {
  background: #3b82f6;
  color: white;
  padding: 0.75rem 2rem;
  border-radius: 0.5rem;
  font-weight: 700;
  border: none;
  cursor: pointer;
  font-size: 1rem;
}

.btn-primary:hover {
  background: #2563eb;
}

.btn-secondary {
  background: #f1f5f9;
  color: #475569;
  padding: 0.75rem 2rem;
  border-radius: 0.5rem;
  font-weight: 700;
  border: 1px solid #cbd5e1;
  text-decoration: none;
  display: inline-block;
}

.btn-secondary:hover {
  background: #e2e8f0;
}
</style>

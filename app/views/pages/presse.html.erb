<%# app/views/pages/presse.html.erb %>

<div class="press-page">

  <%# HERO %>
  <header class="press-hero">
    <div class="container">
      <div class="press-hero-badge">📰 Espace Presse</div>
      <h1 class="press-hero-title">Déclic dans les médias</h1>
      <p class="press-hero-chapo">
        Déclic est une plateforme citoyenne qui met en lumière l'engagement local.<br>
        Découvrez notre kit presse et nos apparitions médias.
      </p>
    </div>
  </header>

  <%# PRÉSENTATION %>
  <section class="press-about">
    <div class="container">
      <div class="press-about-grid">

        <div class="press-about-card">
          <div class="press-about-icon">🎯</div>
          <h3>Notre mission</h3>
          <p>Déclic facilite le passage à l'action en cartographiant les opportunités d'engagement citoyen à Nancy et Paris : bénévolat, formation, entrepreneuriat, transition écologique.</p>
        </div>

        <div class="press-about-card">
          <div class="press-about-icon">📊</div>
          <h3>En chiffres</h3>
          <ul>
            <li><strong>200+</strong> opportunités référencées</li>
            <li><strong>50+</strong> témoignages inspirants</li>
            <li><strong>2 territoires</strong> couverts (Nancy & Paris)</li>
            <li><strong>100%</strong> gratuit et citoyen</li>
          </ul>
        </div>

        <div class="press-about-card">
          <div class="press-about-icon">🌟</div>
          <h3>Notre impact</h3>
          <p>Chaque mois, des centaines de citoyens découvrent des projets locaux grâce à Déclic. Nous mettons en valeur les initiatives qui créent du lien, forment, et transforment nos territoires.</p>
        </div>

      </div>
    </div>
  </section>

  <%# KIT PRESSE %>
  <section class="press-kit">
    <div class="container">

      <div class="press-kit-header">
        <h2>Kit Presse</h2>
        <p>Tous les éléments dont vous avez besoin pour parler de Déclic</p>
      </div>

      <div class="press-kit-grid">

        <div class="press-kit-item">
          <div class="press-kit-icon">📄</div>
          <h3>Communiqué de presse</h3>
          <p>Présentation officielle de Déclic, chiffres clés et citations</p>
          <a href="mailto:contact@declic.site?subject=Demande%20de%20communiqué%20de%20presse" class="press-kit-btn">
            Demander par email
          </a>
        </div>

        <div class="press-kit-item">
          <div class="press-kit-icon">🎨</div>
          <h3>Logos & Visuels</h3>
          <p>Logo Déclic en haute résolution, versions couleur et noir & blanc</p>
          <a href="mailto:contact@declic.site?subject=Demande%20de%20logos" class="press-kit-btn">
            Demander par email
          </a>
        </div>

        <div class="press-kit-item">
          <div class="press-kit-icon">📸</div>
          <h3>Photos & Captures</h3>
          <p>Screenshots de la plateforme, photos d'événements</p>
          <a href="mailto:contact@declic.site?subject=Demande%20de%20visuels" class="press-kit-btn">
            Demander par email
          </a>
        </div>

        <div class="press-kit-item">
          <div class="press-kit-icon">💬</div>
          <h3>Citations</h3>
          <p>Témoignages d'utilisateurs et partenaires</p>
          <a href="mailto:contact@declic.site?subject=Demande%20de%20citations" class="press-kit-btn">
            Demander par email
          </a>
        </div>

      </div>

    </div>
  </section>

  <%# APPARITIONS MÉDIAS %>
  <section class="press-media">
    <div class="container">

      <div class="press-media-header">
        <h2>Ils parlent de nous</h2>
        <p>Déclic dans la presse locale et nationale</p>
      </div>

      <div class="press-media-list">

        <%# Exemple d'article - À adapter avec vos vraies apparitions %>
        <div class="press-media-item">
          <div class="press-media-logo">
            <div class="press-media-placeholder">📰</div>
          </div>
          <div class="press-media-content">
            <div class="press-media-source">L'Est Républicain</div>
            <h3 class="press-media-title">« Déclic : la plateforme qui cartographie l'engagement citoyen à Nancy »</h3>
            <div class="press-media-date">Décembre 2024</div>
            <p class="press-media-excerpt">
              Une nouvelle plateforme numérique permet aux Nancéiens de découvrir facilement les opportunités d'engagement près de chez eux...
            </p>
            <a href="#" class="press-media-link">Lire l'article →</a>
          </div>
        </div>

        <div class="press-media-item">
          <div class="press-media-logo">
            <div class="press-media-placeholder">📻</div>
          </div>
          <div class="press-media-content">
            <div class="press-media-source">France Bleu Lorraine</div>
            <h3 class="press-media-title">« Comment s'engager localement grâce au numérique ? »</h3>
            <div class="press-media-date">Novembre 2024</div>
            <p class="press-media-excerpt">
              Interview des fondateurs de Déclic sur les nouvelles formes d'engagement citoyen facilitées par le digital...
            </p>
            <a href="#" class="press-media-link">Écouter l'interview →</a>
          </div>
        </div>

        <div class="press-media-item">
          <div class="press-media-logo">
            <div class="press-media-placeholder">📺</div>
          </div>
          <div class="press-media-content">
            <div class="press-media-source">France 3 Grand Est</div>
            <h3 class="press-media-title">« Déclic, l'appli qui donne envie de passer à l'action »</h3>
            <div class="press-media-date">Octobre 2024</div>
            <p class="press-media-excerpt">
              Reportage sur la plateforme Déclic et les témoignages de citoyens qui ont trouvé leur voie grâce aux opportunités référencées...
            </p>
            <a href="#" class="press-media-link">Voir le reportage →</a>
          </div>
        </div>

        <%# Message si aucune apparition réelle pour l'instant %>
        <div class="press-media-empty">
          <p><em>🚀 Déclic est un projet récent. Les premières apparitions médias arriveront bientôt ! Vous êtes journaliste ? <a href="mailto:contact@declic.site">Contactez-nous</a>.</em></p>
        </div>

      </div>

    </div>
  </section>

  <%# CONTACT PRESSE %>
  <section class="press-contact">
    <div class="container">
      <div class="press-contact-card">
        <div class="press-contact-icon">✉️</div>
        <h2>Contact Presse</h2>
        <p>Vous souhaitez réaliser un sujet sur Déclic ?</p>
        <div class="press-contact-info">
          <div class="press-contact-line">
            <span class="press-contact-label">Email :</span>
            <a href="mailto:contact@declic.site">contact@declic.site</a>
          </div>
          <div class="press-contact-line">
            <span class="press-contact-label">Réponse :</span>
            <span>Sous 24h</span>
          </div>
        </div>
        <a href="mailto:contact@declic.site?subject=Demande%20presse" class="press-contact-btn">
          Nous contacter
        </a>
      </div>
    </div>
  </section>

</div>

<style>
/* BASE */
.press-page {
  font-family: "Inter", system-ui, sans-serif;
  color: #0f172a;
  background: white;
  min-height: 100vh;
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
}

/* HERO */
.press-hero {
  background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%);
  padding: 80px 24px 60px;
  text-align: center;
  border-bottom: 2px solid #e9d5ff;
}

.press-hero-badge {
  display: inline-block;
  background: linear-gradient(135deg, #a855f7, #ec4899);
  color: white;
  font-weight: 800;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 8px 20px;
  border-radius: 999px;
  margin-bottom: 20px;
  box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
}

.press-hero-title {
  font-family: "Epilogue", sans-serif;
  font-weight: 900;
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  line-height: 1.1;
  margin: 0 0 16px;
  background: linear-gradient(135deg, #7e22ce, #a855f7, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.press-hero-chapo {
  font-size: 1.15rem;
  color: #64748b;
  max-width: 700px;
  margin: 0 auto;
  line-height: 1.6;
}

/* PRÉSENTATION */
.press-about {
  padding: 60px 0;
  background: white;
}

.press-about-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 32px;
}

.press-about-card {
  background: linear-gradient(135deg, #faf5ff, #f3e8ff);
  border: 2px solid #e9d5ff;
  border-radius: 20px;
  padding: 32px;
  text-align: center;
}

.press-about-icon {
  font-size: 3rem;
  margin-bottom: 16px;
}

.press-about-card h3 {
  font-family: "Epilogue", sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  color: #1e293b;
  margin: 0 0 12px;
}

.press-about-card p {
  color: #475569;
  font-size: 1rem;
  line-height: 1.6;
  margin: 0;
}

.press-about-card ul {
  list-style: none;
  padding: 0;
  margin: 0;
  color: #475569;
  font-size: 1rem;
  line-height: 1.8;
}

.press-about-card li strong {
  color: #a855f7;
  font-weight: 800;
}

/* KIT PRESSE */
.press-kit {
  padding: 60px 0;
  background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
}

.press-kit-header {
  text-align: center;
  margin-bottom: 48px;
}

.press-kit-header h2 {
  font-family: "Epilogue", sans-serif;
  font-weight: 900;
  font-size: 2.5rem;
  color: #1e293b;
  margin: 0 0 12px;
}

.press-kit-header p {
  font-size: 1.15rem;
  color: #64748b;
  margin: 0;
}

.press-kit-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
}

.press-kit-item {
  background: white;
  border: 2px solid #e2e8f0;
  border-radius: 20px;
  padding: 32px;
  text-align: center;
  transition: all 0.2s;
}

.press-kit-item:hover {
  border-color: #e9d5ff;
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(168, 85, 247, 0.15);
}

.press-kit-icon {
  font-size: 2.5rem;
  margin-bottom: 16px;
}

.press-kit-item h3 {
  font-family: "Epilogue", sans-serif;
  font-weight: 700;
  font-size: 1.25rem;
  color: #1e293b;
  margin: 0 0 12px;
}

.press-kit-item p {
  color: #64748b;
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0 0 20px;
}

.press-kit-btn {
  display: inline-block;
  background: linear-gradient(135deg, #a855f7, #ec4899);
  color: white;
  padding: 12px 24px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all 0.2s;
}

.press-kit-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 6px 20px rgba(168, 85, 247, 0.4);
}

/* APPARITIONS MÉDIAS */
.press-media {
  padding: 60px 0;
  background: white;
}

.press-media-header {
  text-align: center;
  margin-bottom: 48px;
}

.press-media-header h2 {
  font-family: "Epilogue", sans-serif;
  font-weight: 900;
  font-size: 2.5rem;
  color: #1e293b;
  margin: 0 0 12px;
}

.press-media-header p {
  font-size: 1.15rem;
  color: #64748b;
  margin: 0;
}

.press-media-list {
  max-width: 800px;
  margin: 0 auto;
}

.press-media-item {
  background: white;
  border: 2px solid #e2e8f0;
  border-radius: 20px;
  padding: 32px;
  margin-bottom: 24px;
  display: flex;
  gap: 24px;
  align-items: start;
  transition: all 0.2s;
}

.press-media-item:hover {
  border-color: #e9d5ff;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

.press-media-logo {
  flex-shrink: 0;
}

.press-media-placeholder {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #f3e8ff, #e9d5ff);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
}

.press-media-content {
  flex: 1;
}

.press-media-source {
  font-weight: 800;
  font-size: 0.85rem;
  color: #a855f7;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.press-media-title {
  font-family: "Epilogue", sans-serif;
  font-weight: 700;
  font-size: 1.25rem;
  color: #1e293b;
  margin: 0 0 8px;
  line-height: 1.3;
}

.press-media-date {
  font-size: 0.85rem;
  color: #94a3b8;
  font-weight: 600;
  margin-bottom: 12px;
}

.press-media-excerpt {
  color: #64748b;
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0 0 16px;
}

.press-media-link {
  color: #a855f7;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  border-bottom: 2px solid #e9d5ff;
  transition: border-color 0.2s;
}

.press-media-link:hover {
  border-bottom-color: #a855f7;
}

.press-media-empty {
  text-align: center;
  padding: 48px 24px;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 20px;
  border: 2px solid #fbbf24;
}

.press-media-empty p {
  font-size: 1.05rem;
  color: #78350f;
  margin: 0;
  line-height: 1.7;
}

.press-media-empty a {
  color: #92400e;
  font-weight: 700;
  text-decoration: underline;
}

/* CONTACT PRESSE */
.press-contact {
  padding: 80px 24px;
  background: linear-gradient(135deg, #1e293b, #0f172a);
}

.press-contact-card {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}

.press-contact-icon {
  font-size: 4rem;
  margin-bottom: 24px;
}

.press-contact-card h2 {
  font-family: "Epilogue", sans-serif;
  font-weight: 800;
  font-size: 2.5rem;
  color: white;
  margin: 0 0 12px;
}

.press-contact-card > p {
  font-size: 1.25rem;
  color: #cbd5e1;
  margin: 0 0 32px;
}

.press-contact-info {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 32px;
}

.press-contact-line {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
  font-size: 1.05rem;
}

.press-contact-line:last-child {
  margin-bottom: 0;
}

.press-contact-label {
  color: #94a3b8;
  font-weight: 600;
}

.press-contact-line a,
.press-contact-line span {
  color: white;
  font-weight: 700;
  text-decoration: none;
}

.press-contact-line a:hover {
  text-decoration: underline;
}

.press-contact-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #a855f7, #ec4899);
  color: white;
  padding: 18px 40px;
  border-radius: 999px;
  font-weight: 700;
  font-size: 1.1rem;
  text-decoration: none;
  box-shadow: 0 10px 40px rgba(168, 85, 247, 0.4);
  transition: all 0.2s;
}

.press-contact-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 50px rgba(168, 85, 247, 0.5);
}

/* RESPONSIVE */
@media (max-width: 640px) {
  .press-hero {
    padding: 60px 20px 40px;
  }

  .press-hero-title {
    font-size: 2rem;
  }

  .press-about-grid,
  .press-kit-grid {
    grid-template-columns: 1fr;
  }

  .press-media-item {
    flex-direction: column;
    text-align: center;
  }

  .press-media-logo {
    margin: 0 auto;
  }

  .press-contact {
    padding: 60px 20px;
  }

  .press-contact-card h2 {
    font-size: 2rem;
  }

  .press-contact-line {
    flex-direction: column;
    gap: 4px;
  }
}
</style>

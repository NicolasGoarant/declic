<%# ---------- META ---------- %>
<% content_for :head do %>
  <meta property="og:title" content="Presse & média — Déclic">
  <meta property="og:description" content="Kit média, logos, captures d’écran, chiffres clés et contact presse.">
  <meta name="robots" content="index,follow">
<% end %>

<%# Helpers de petite mise en forme %>
<% def stat_row(label, value) %>
  <div class="flex items-baseline justify-between py-2">
    <span class="text-slate-600"><%= label %></span>
    <span class="font-semibold text-slate-900"><%= value %></span>
  </div>
<% end %>

<main class="max-w-6xl mx-auto px-6 py-10">
  <div class="mb-6">
    <%= link_to "← Accueil", root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <!-- HERO -->
  <header class="rounded-2xl bg-gradient-to-r from-indigo-600 to-fuchsia-600 text-white p-6 ring-1 ring-black/10">
    <h1 class="text-2xl sm:text-3xl font-extrabold">Presse & média</h1>
    <p class="mt-2 text-white/90 max-w-3xl">
      Ressources pour couvrir Déclic : kit média, logos, visuels, chiffres clés et contact presse.
    </p>
  </header>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-[280px_minmax(0,1fr)] gap-8">
    <!-- SIDE NAV -->
    <aside class="lg:sticky lg:top-24 self-start">
      <nav class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-4 text-sm">
        <p class="font-semibold text-slate-900 mb-2">Sommaire</p>
        <ul class="space-y-2">
          <li><a href="#kit" class="block text-slate-600 hover:text-indigo-600">• Kit média (zip)</a></li>
          <li><a href="#logos" class="block text-slate-600 hover:text-indigo-600">• Logos & charte</a></li>
          <li><a href="#captures" class="block text-slate-600 hover:text-indigo-600">• Captures d’écran</a></li>
          <li><a href="#chiffres" class="block text-slate-600 hover:text-indigo-600">• Chiffres clés</a></li>
          <li><a href="#boiler" class="block text-slate-600 hover:text-indigo-600">• Boilerplate</a></li>
          <li><a href="#citations" class="block text-slate-600 hover:text-indigo-600">• Citations</a></li>
          <li><a href="#contact" class="block text-slate-600 hover:text-indigo-600">• Contact presse</a></li>
        </ul>
      </nav>
    </aside>

    <!-- CONTENT -->
    <section class="space-y-6">
      <article id="kit" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-xl font-bold text-slate-900">Kit média</h2>
        <p class="mt-2 text-slate-700">
          Télécharge l’ensemble des éléments (logos, visuels, captures, boilerplate) dans une archive unique.
        </p>
        <div class="mt-4">
          <%= link_to "Télécharger le kit (.zip)", asset_path("media/declic-presskit.zip"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700" rescue nil %>
          <% if (rescue nil).nil? %>
            <p class="text-sm text-slate-500 mt-3">Place le fichier à <code>app/assets/media/declic-presskit.zip</code> pour activer ce bouton.</p>
          <% end %>
        </div>
      </article>

      <article id="logos" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Logos & charte d’usage</h2>
        <p class="mt-2 text-slate-700">
          Utilise le logo sur fond clair ou foncé. Garde un pourtour d’au moins 8&nbsp;px et évite toute déformation.
        </p>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-lg ring-1 ring-gray-200 p-4">
            <p class="text-sm text-slate-600 mb-2">Logo fond clair (SVG)</p>
            <%= image_tag "brand/logo-declic.svg", class: "h-12", alt: "Logo Déclic" rescue "" %>
            <div class="mt-3">
              <%= link_to "Télécharger", asset_path("brand/logo-declic.svg"), class: "text-indigo-600 underline" rescue nil %>
            </div>
          </div>
          <div class="rounded-lg ring-1 ring-gray-200 p-4 bg-slate-900">
            <p class="text-sm text-slate-300 mb-2">Logo fond sombre (SVG)</p>
            <%= image_tag "brand/logo-declic-white.svg", class: "h-12", alt: "Logo Déclic (inversé)" rescue "" %>
            <div class="mt-3">
              <%= link_to "Télécharger", asset_path("brand/logo-declic-white.svg"), class: "text-indigo-300 underline" rescue nil %>
            </div>
          </div>
        </div>
      </article>

      <article id="captures" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Captures d’écran</h2>
        <p class="mt-2 text-slate-700">Exemples d’écrans : accueil, carte, fiche opportunité.</p>
        <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
          <% ["screens/home.png","screens/map.png","screens/opportunity.png"].each do |p| %>
            <div class="overflow-hidden rounded-lg ring-1 ring-gray-200">
              <%= image_tag p, class: "w-full h-40 object-cover", alt: "Capture #{p}" rescue "" %>
            </div>
          <% end %>
        </div>
      </article>

      <article id="chiffres" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Chiffres clés</h2>
        <div class="mt-2 divide-y divide-gray-200">
          <%= stat_row("Opportunités en base", (Opportunity.count rescue 0)) %>
          <%= stat_row("Histoires publiées", (Story.count rescue 0)) %>
          <%= stat_row("Témoignages", (Testimonial.count rescue 0)) %>
          <%= stat_row("Villes couvertes (approx.)", ((Opportunity.distinct.count(:location) rescue 0))) %>
        </div>
      </article>

      <article id="boiler" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Boilerplate (copier/coller)</h2>
        <p class="mt-2 text-slate-700">
          <strong>Déclic</strong> aide chacun à <em>passer à l’action près de chez soi</em> : entreprendre, se former,
          rencontrer, aider — et s’inspirer de belles histoires locales. Projet citoyen, Déclic agrège des
          opportunités vérifiées et rend la mise en relation simple et concrète.
        </p>
      </article>

      <article id="citations" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Citations</h2>
        <ul class="mt-2 space-y-3 text-slate-700">
          <li>« On a plein d’envies, mais on ne sait pas par où commencer. Déclic montre des portes d’entrée locales, concrètes. »</li>
          <li>« Le meilleur moteur, c’est l’exemple : voir un voisin qui lance, ça donne envie d’essayer. »</li>
        </ul>
      </article>

      <article id="contact" class="rounded-xl bg-white ring-1 ring-gray-200 shadow p-6">
        <h2 class="text-lg font-semibold text-slate-900">Contact presse</h2>
        <p class="mt-2 text-slate-700">
          <a href="mailto:nicolas.goarant@hotmail.fr" class="text-indigo-600 underline">nicolas.goarant@hotmail.fr</a> — +33 6 67 06 31 79
        </p>
      </article>
    </section>
  </div>
</main>

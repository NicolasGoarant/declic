<%# app/views/shared/_pwa_banner.html.erb %>
<div id="pwa-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; padding:12px 16px; background:white; border-top:0.5px solid #e5e7eb; box-shadow:0 -2px 12px rgba(0,0,0,0.08);">
  <div style="max-width:480px; margin:0 auto; display:flex; align-items:center; gap:12px;">
    <div style="width:40px; height:40px; border-radius:10px; background:linear-gradient(135deg,#c026d3,#4f46e5); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
      <span style="color:white; font-weight:600; font-size:18px;">D</span>
    </div>
    <div style="flex:1; min-width:0;">
      <p style="margin:0; font-size:14px; font-weight:600; color:#111827;">Installer Déclic</p>
      <p id="pwa-banner-sub" style="margin:0; font-size:12px; color:#6b7280;">Accès rapide depuis ton écran d'accueil</p>
    </div>
    <button id="pwa-install-btn" style="background:#7c3aed; color:white; border:none; border-radius:8px; padding:8px 14px; font-size:13px; font-weight:500; cursor:pointer;">
      Installer
    </button>
    <button id="pwa-dismiss-btn" style="background:none; border:none; color:#9ca3af; cursor:pointer; font-size:22px; padding:0 4px; line-height:1;">
      &times;
    </button>
  </div>
</div>

<script>
  (function() {
    var banner = document.getElementById('pwa-banner');
    var installBtn = document.getElementById('pwa-install-btn');
    var dismissBtn = document.getElementById('pwa-dismiss-btn');
    var sub = document.getElementById('pwa-banner-sub');
    var deferredPrompt = null;

    var isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent) && !window.MSStream;
    var isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    var isChromeiOS = isIOS && /CriOS/i.test(navigator.userAgent);

    if (window.matchMedia('(display-mode: standalone)').matches) return;

    var views = parseInt(localStorage.getItem('pwa-banner-views') || '0');
    if (views >= 3) return;

    window.addEventListener('beforeinstallprompt', function(e) {
      e.preventDefault();
      deferredPrompt = e;
    });

    if (window.innerWidth < 768) {
      setTimeout(function() {
        if (isChromeiOS) {
          sub.textContent = 'Ouvre declic.site dans Safari pour installer l\'app';
          installBtn.style.display = 'none';
        } else if (isIOS && isSafari) {
          sub.textContent = 'Appuie sur ⬆ Partager puis "Sur l\'écran d\'accueil"';
          installBtn.style.display = 'none';
        }
        banner.style.display = 'block';
        localStorage.setItem('pwa-banner-views', views + 1);
      }, 3000);
    }

    installBtn.addEventListener('click', function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function() {
          deferredPrompt = null;
          banner.style.display = 'none';
          localStorage.setItem('pwa-banner-views', '99');
        });
      } else {
        banner.style.display = 'none';
      }
    });

    dismissBtn.addEventListener('click', function() {
      banner.style.display = 'none';
    });
  })();
</script>
